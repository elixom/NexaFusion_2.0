{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "840px",
			"wideSize": "1280px"
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},
		"typography": {
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "Manrope, sans-serif",
					"slug": "display",
					"name": "Display"
				},
				{
					"fontFamily": "Inter, sans-serif",
					"slug": "body",
					"name": "Body"
				}
			],
			"fontSizes": [
				{
					"slug": "label-md",
					"size": "0.875rem",
					"name": "Label Medium"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large"
				},
				{
					"slug": "display-md",
					"size": "2.5rem",
					"name": "Display Medium"
				},
				{
					"slug": "display-lg",
					"size": "3.5rem",
					"name": "Display Large"
				}
			]
		},
		"color": {
			"defaultPalette": false,
			"customDuotone": false,
			"custom": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#7d98ff",
					"name": "Primary"
				},
				{
					"slug": "primary-container",
					"color": "#275dfb",
					"name": "Primary Container"
				},
				{
					"slug": "on-primary",
					"color": "#00185c",
					"name": "On Primary"
				},
				{
					"slug": "on-primary-container",
					"color": "#ffffff",
					"name": "On Primary Container"
				},
				{
					"slug": "tertiary",
					"color": "#ddb7ff",
					"name": "Tertiary"
				},
				{
					"slug": "surface",
					"color": "#070d1f",
					"name": "Surface"
				},
				{
					"slug": "surface-container-low",
					"color": "#0b1228",
					"name": "Surface Container Low"
				},
				{
					"slug": "surface-container",
					"color": "#0f1832",
					"name": "Surface Container"
				},
				{
					"slug": "surface-container-high",
					"color": "#131e3c",
					"name": "Surface Container High"
				},
				{
					"slug": "surface-container-highest",
					"color": "#182446",
					"name": "Surface Container Highest"
				},
				{
					"slug": "surface-bright",
					"color": "#1c2a51",
					"name": "Surface Bright"
				},
				{
					"slug": "secondary-container",
					"color": "#18263d",
					"name": "Secondary Container"
				},
				{
					"slug": "on-secondary-container",
					"color": "#96a4c0",
					"name": "On Secondary Container"
				},
				{
					"slug": "on-surface",
					"color": "#ffffff",
					"name": "On Surface"
				},
				{
					"slug": "on-surface-variant",
					"color": "#9eaad3",
					"name": "On Surface Variant"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--on-surface-variant)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--tertiary)"
					}
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--on-primary-container)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--display-lg)",
					"fontWeight": "800"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "portfolio",
			"title": "Portfolio Layout",
			"postTypes": ["page"]
		},
		{
			"name": "testimonials",
			"title": "Testimonials Layout",
			"postTypes": ["page"]
		}
	]
}
