{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "840px",
			"wideSize": "1280px"
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},
		"typography": {
			"dropCap": false,
			"fluid": true,
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "1.875rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "3rem",
					"name": "2X Large"
				}
			]
		},
		"color": {
			"defaultPalette": false,
			"customDuotone": false,
			"custom": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#7d98ff",
					"name": "Primary"
				},
				{
					"slug": "primary-container",
					"color": "#275dfb",
					"name": "Primary Container"
				},
				{
					"slug": "tertiary",
					"color": "#ddb7ff",
					"name": "Tertiary"
				},
				{
					"slug": "surface",
					"color": "#070d1f",
					"name": "Surface"
				},
				{
					"slug": "surface-container-low",
					"color": "#0b1228",
					"name": "Surface Container Low"
				},
				{
					"slug": "surface-container-high",
					"color": "#131e3c",
					"name": "Surface Container High"
				},
				{
					"slug": "on-surface",
					"color": "#dfe4ff",
					"name": "On Surface"
				},
				{
					"slug": "on-surface-variant",
					"color": "#9eaad3",
					"name": "On Surface Variant"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--on-surface)"
		},
		"typography": {
			"fontFamily": "Inter, sans-serif",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--tertiary)"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "Manrope, sans-serif",
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "3rem",
					"fontWeight": "800"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
